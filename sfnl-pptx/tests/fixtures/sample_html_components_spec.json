{
  "schema_version": "1.0",
  "meta": {
    "title": "HTML-derived SFNL components",
    "lang": "nl",
    "accent": "orange",
    "output": "output/html-components-demo.pptx"
  },
  "narrative": "HTML-templatepatronen worden vertaald naar aanpasbare PowerPoint-componenten in SFNL-stijl.",
  "slides": [
    {
      "id": "s1",
      "type": "matrix",
      "component_id": "matrix-2x2",
      "action_title": "Een 2x2 matrix maakt keuzes direct scanbaar",
      "visual": {"x": 0.95, "y": 1.95, "width": 6.8, "height": 4.2},
      "content_schema_fill": {
        "title": "Impact versus risico",
        "x_axis": "Risico",
        "y_axis": "Effect",
        "quadrants": [
          {"heading": "Strategisch", "body": "Bouwen en versnellen", "color": "emerald"},
          {"heading": "Kans", "body": "Pilot en valideren", "color": "sky"},
          {"heading": "Basis", "body": "Behouden", "color": "royal"},
          {"heading": "Vermijden", "body": "Stoppen of herontwerpen", "color": "grapefruit"}
        ]
      }
    },
    {
      "id": "s2",
      "type": "layer-stack",
      "component_id": "layer-stack",
      "action_title": "Een layer stack laat analytische bewijslast oplopen",
      "visual": {"x": 1.0, "y": 2.0, "width": 8.8, "layer_height": 0.55, "indent": 0.38},
      "content_schema_fill": {
        "title": "Vijf evidence-lagen",
        "layers": [
          {"label": "Niveau 5", "detail": "Strategische beslissing", "color": "navy"},
          {"label": "Niveau 4", "detail": "Synthese over programma's", "color": "royal"},
          {"label": "Niveau 3", "detail": "Evidence per thema", "color": "sky"},
          {"label": "Niveau 2", "detail": "Data en metingen", "color": "emerald"},
          {"label": "Niveau 1", "detail": "Operationele registratie", "color": "orange"}
        ]
      }
    },
    {
      "id": "s3",
      "type": "cycle",
      "component_id": "cycle-diagram",
      "action_title": "Een cyclusdiagram toont continu leren zonder eindpunt",
      "visual": {"center_x": 6.6, "center_y": 3.9, "radius": 1.65, "node_size": 0.92},
      "content_schema_fill": {
        "title": "Continu verbeteren",
        "center": "Continu",
        "steps": [
          {"label": "Plannen", "color": "orange", "icon": "1"},
          {"label": "Uitvoeren", "color": "grapefruit", "icon": "2"},
          {"label": "Meten", "color": "sky", "icon": "3"},
          {"label": "Bijsturen", "color": "royal", "icon": "4"}
        ]
      }
    },
    {
      "id": "s4",
      "type": "scenario",
      "component_id": "scenario-cards",
      "action_title": "Scenario's krijgen elk een eigen kaart met afwegingen",
