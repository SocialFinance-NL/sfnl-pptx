      "content_schema_fill": {
        "title": "Drie scenario's",
        "scenarios": [
          {"heading": "Scenario A", "subtitle": "Status quo", "color": "sky", "pros": ["Bekende werkwijze", "Beperkte investering"], "cons": ["Risico op stilstand"]},
          {"heading": "Scenario B", "subtitle": "Regionaal model", "color": "emerald", "pros": ["Meer schaal", "Gedeeld risico"], "cons": ["Governance-uitdaging"]},
          {"heading": "Scenario C", "subtitle": "Privaat kapitaal", "color": "grapefruit", "pros": ["Maximale hefboom", "Snelle uitrol"], "cons": ["Hogere kosten"]}
        ]
      }
    },
    {
      "id": "s5",
      "type": "assessment",
      "component_id": "assessment-table",
      "action_title": "Een afwegingskader combineert criteria en scores",
      "visual": {"x": 0.75, "y": 1.8, "width": 10.9, "row_height": 0.62},
      "content_schema_fill": {
        "title": "Afwegingskader",
        "columns": ["Criterium", "Toelichting", "Score"],
        "rows": [
          {"criterion": "Realiseerbaarheid", "description": "Haalbaar binnen scope en tijd", "score": "Middel", "color": "sky"},
          {"criterion": "Financieel", "description": "Kosten versus beschikbaar budget", "score": "Hoog", "color": "emerald"},
          {"criterion": "Draagvlak", "description": "Steun bij partners en doelgroep", "score": "Middel", "color": "orange"},
          {"criterion": "Toegevoegde waarde", "description": "Meetbaar effect op doelen", "score": "Hoog", "color": "emerald"}
        ]
      }
    },
    {
      "id": "s6",
      "type": "mechanism",
      "component_id": "mechanism-diagram",
      "action_title": "Een mechaniekdiagram maakt rollen en geldstromen zichtbaar",
      "visual": {"center_x": 6.4, "center_y": 3.75, "node_width": 2.0, "node_height": 0.82, "radius_x": 3.6, "radius_y": 1.75},
      "content_schema_fill": {
        "title": "Mechaniek",
        "center": {"heading": "Maatwerkbudget", "body": "beheerd door uitvoerende partij", "color": "orange"},
        "nodes": [
          {"heading": "Opdrachtgever", "body": "beleid en toezicht", "color": "navy", "icon": "target"},
          {"heading": "Financier", "body": "fonds of gemeente", "color": "royal", "icon": "money"},
          {"heading": "Deelnemers", "body": "burgers of doelgroep", "color": "sky", "icon": "people"},
          {"heading": "Learning partner", "body": "meting en evaluatie", "color": "emerald", "icon": "chart"}
        ],
        "flows": [
          {"from": "center", "to": 0, "label": "Budget"},
          {"from": 0, "to": "center", "label": "Opdracht"},
          {"from": "center", "to": 2, "label": "Uitvoering"},
          {"from": 3, "to": "center", "label": "Evidence"}
        ]
      }
    }
  ]
}
